{
  "name": "nextjs-application",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "eslint src --fix && prettier --write 'src/**/*.{js,jsx,ts,tsx}' && next build",
    "start": "next start",
    "lint": "eslint src --fix && prettier --write 'src/**/*.{js,jsx,ts,tsx}'",
    "analyzer": "set ANALYZE=true&&next dev",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "next": "^16",
    "next-auth": "^4.24.5",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16",
    "@storybook/addon-links": "^9.1.20",
    "@storybook/nextjs": "^9.1.20",
    "@storybook/react": "^9.1.20",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@eslint/eslintrc": "^3",
    "@typescript-eslint/eslint-plugin": "^8",
    "eslint": "^9",
    "eslint-config-next": "^16",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-storybook": "^0.11.0",
"storybook": "^9.1.20",
    "typescript": "^5"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
